PORT=3001
CORS_ORIGIN=*

# Use DATABASE_URL for Supabase or another hosted Postgres provider.
# Keep this value out of Git. Copy this file to .env and fill it locally.
DATABASE_URL=
DATABASE_SSL=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=subscription_user
POSTGRES_PASSWORD=subscription_password
POSTGRES_DB=subscription_manager

TYPEORM_SYNC=true
TYPEORM_LOGGING=false
SEED_DATABASE=true
